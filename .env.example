# ============================================
# Folio Environment Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env to git!
# ============================================

# --- Deploy Webhook + Cloud Sync Server ---
# Secret for GitHub webhook verification and cloud sync authentication
# Generate a strong random string for production
DEPLOY_SECRET=your-secure-secret-here-change-me

# Public URL for client auto-discovery (optional)
# Set this to your server's IP/hostname so mobile apps can auto-find it
# Example: http://192.168.1.100:9000 or https://folio.yourdomain.com
PUBLIC_SERVER_URL=

# --- Optional: Separate API key for cloud sync ---
# If not set, DEPLOY_SECRET will be used for both
# FOLIO_API_KEY=your-sync-secret-here

# ============================================
# Security Notes:
# - Keep this file private (add .env to .gitignore)
# - Use strong, randomly generated secrets
# - Rotate secrets periodically
# ============================================
